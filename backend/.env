DB_PASSWORD=binayak10
 
# ── Google OAuth ──────────────────────────────────────
# Get these from https://console.cloud.google.com
# Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
 
# ── JWT ───────────────────────────────────────────────
# Use any long random string — keep it secret!
JWT_SECRET=change_this_to_a_long_random_secret_string_123456
 
# ── Frontend ──────────────────────────────────────────
# Where your Vite frontend runs
FRONTEND_URL=http://localhost:5173
 